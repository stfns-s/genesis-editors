{
  "name": "genesispy",
  "displayName": "Genesispy",
  "description": "Syntax highlighting for genesispy Python-templated Verilog (.vpy / .svpy / .gvpy / .vpyh).",
  "version": "0.3.0",
  "publisher": "genesispy",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "extensionDependencies": [
    "mshr-h.veriloghdl"
  ],
  "contributes": {
    "languages": [
      {
        "id": "genesispy",
        "aliases": [
          "Genesispy",
          "genesispy"
        ],
        "extensions": [
          ".vpy",
          ".svpy",
          ".gvpy",
          ".vpyh"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "genesispy",
        "scopeName": "source.genesispy",
        "path": "./syntaxes/genesispy.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.line.python": "python",
          "meta.embedded.block.python": "python",
          "source.systemverilog": "systemverilog"
        }
      }
    ]
  }
}
