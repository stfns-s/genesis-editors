{
  "name": "genesis2",
  "displayName": "Genesis2",
  "description": "Syntax highlighting for Genesis2 Perl-templated Verilog (.vp / .svp / .vph).",
  "version": "0.3.0",
  "publisher": "genesispy",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "extensionDependencies": [
    "mshr-h.veriloghdl"
  ],
  "contributes": {
    "languages": [
      {
        "id": "genesis2",
        "aliases": [
          "Genesis2",
          "genesis2"
        ],
        "extensions": [
          ".vp",
          ".svp",
          ".vph"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "genesis2",
        "scopeName": "source.genesis2",
        "path": "./syntaxes/genesis2.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.line.perl": "perl",
          "meta.embedded.block.perl": "perl",
          "source.systemverilog": "systemverilog"
        }
      }
    ]
  }
}
